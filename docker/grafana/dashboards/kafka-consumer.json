{
  "uid": "kafka-consumer",
  "title": "WealthPay — Kafka Consumer",
  "tags": ["wealthpay", "kafka"],
  "timezone": "browser",
  "refresh": "15s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Consumer Lag (max)",
      "description": "If this grows, the read projection is falling behind the event store",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag_max{job=\"wealthpay\"}",
          "legendFormat": "lag max"
        },
        {
          "expr": "kafka_consumer_fetch_manager_records_lag{job=\"wealthpay\"}",
          "legendFormat": "lag {{topic}}-{{partition}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Records Consumed Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_consumed_rate{job=\"wealthpay\"}",
          "legendFormat": "records/s"
        }
      ]
    },
    {
      "id": 3,
      "title": "Spring Kafka Listener Duration",
      "description": "How long the projection handler takes per event batch",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "max(spring_kafka_listener_seconds_max{job=\"wealthpay\"}) by (name)",
          "legendFormat": "max {{name}}"
        },
        {
          "expr": "sum(rate(spring_kafka_listener_seconds_sum{job=\"wealthpay\"}[5m])) by (name) / sum(rate(spring_kafka_listener_seconds_count{job=\"wealthpay\"}[5m])) by (name)",
          "legendFormat": "avg {{name}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Listener Invocations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(spring_kafka_listener_seconds_count{job=\"wealthpay\"}[5m])) by (name)",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Fetch Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_fetch_latency_avg{job=\"wealthpay\"}",
          "legendFormat": "avg"
        },
        {
          "expr": "kafka_consumer_fetch_manager_fetch_latency_max{job=\"wealthpay\"}",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 6,
      "title": "Commit Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "kafka_consumer_coordinator_commit_latency_avg{job=\"wealthpay\"}",
          "legendFormat": "avg"
        },
        {
          "expr": "kafka_consumer_coordinator_commit_latency_max{job=\"wealthpay\"}",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 7,
      "title": "Rebalances",
      "description": "Frequent rebalances indicate consumer instability",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "increase(kafka_consumer_coordinator_rebalance_total{job=\"wealthpay\"}[5m])",
          "legendFormat": "total rebalances"
        },
        {
          "expr": "increase(kafka_consumer_coordinator_failed_rebalance_total{job=\"wealthpay\"}[5m])",
          "legendFormat": "failed rebalances"
        }
      ]
    },
    {
      "id": 8,
      "title": "Consumer Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "kafka_consumer_connection_count{job=\"wealthpay\"}",
          "legendFormat": "active connections"
        },
        {
          "expr": "kafka_consumer_coordinator_assigned_partitions{job=\"wealthpay\"}",
          "legendFormat": "assigned partitions"
        }
      ]
    },
    {
      "id": 9,
      "title": "Consumer Poll Idle Ratio",
      "description": "Close to 1.0 = consumer is idle most of the time. Close to 0 = consumer is busy processing",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "fillOpacity": 15 },
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "kafka_consumer_poll_idle_ratio_avg{job=\"wealthpay\"}",
          "legendFormat": "poll idle ratio"
        }
      ]
    },
    {
      "id": 10,
      "title": "Bytes Consumed Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_bytes_consumed_rate{job=\"wealthpay\"}",
          "legendFormat": "bytes/s"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus (Main)", "value": "Prometheus (Main)" }
      }
    ]
  },
  "schemaVersion": 39
}
